{
  "manifest_version": 3,
  "name": "Video Saver - Instagram & X Downloader",
  "version": "1.0.2",
  "description": "Download public videos from Instagram Reels and Twitter/X on demand. Zero background activity — only runs when you click.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://cdn.syndication.twimg.com/*",
    "https://video.twimg.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://*.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}